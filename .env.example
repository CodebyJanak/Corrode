# Corrode — API Keys (never commit this file)
# Get a free Groq key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OR use Gemini (free tier) at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Which AI provider to use: "groq" | "gemini"
AI_PROVIDER=groq

# Free weather API — get key at https://openweathermap.org/api
WEATHER_API_KEY=your_openweather_api_key_here
