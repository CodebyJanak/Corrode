{
  "name": "corrode",
  "version": "0.1.0",
  "description": "The browser from 2035.",
  "main": "main/index.js",
  "scripts": {
    "start": "concurrently \"npm run vite\" \"wait-on http://localhost:5173 && electron .\"",
    "vite": "vite",
